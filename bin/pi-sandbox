#!/usr/bin/env bash
set -euo pipefail

IMAGE_NAME="${PI_SANDBOX_IMAGE:-pi-sandbox}"
CONTAINER_NAME="${PI_SANDBOX_CONTAINER:-pi-sandbox}"
CONTAINER_WORKDIR="/workspace"

DOCKERFILE_PATH="${PI_SANDBOX_DOCKERFILE:-$HOME/agent-images/Dockerfile.pi}"
BUILD_CONTEXT="${PI_SANDBOX_BUILD_CONTEXT:-$HOME/agent-images}"

MISE_CONFIG_HOST="${MISE_CONFIG_HOST:-$HOME/.config/mise}"
AGENT_ENV_DOCTOR_HOST="${AGENT_ENV_DOCTOR_HOST:-$HOME/.local/bin/agent-env-doctor}"

RUN_MODE="pi"
if [ "${1:-}" = "doctor" ]; then
  RUN_MODE="doctor"
  shift
fi

docker volume inspect pi-sandbox-home >/dev/null 2>&1 \
  || docker volume create pi-sandbox-home >/dev/null

if [ ! -f "$AGENT_ENV_DOCTOR_HOST" ]; then
  echo "agent-env-doctor not found: $AGENT_ENV_DOCTOR_HOST" >&2
  exit 1
fi

docker build \
  -t "$IMAGE_NAME" \
  -f "$DOCKERFILE_PATH" \
  "$BUILD_CONTEXT"

MISE_CONFIG_MOUNT=()
if [ -d "$MISE_CONFIG_HOST" ]; then
  MISE_CONFIG_MOUNT=(--volume "$MISE_CONFIG_HOST:/root/.config/mise:ro")
fi

docker run --rm -it \
  --name "$CONTAINER_NAME" \
  --workdir "$CONTAINER_WORKDIR" \
  --volume "$PWD:$CONTAINER_WORKDIR" \
  --volume pi-sandbox-home:/persist \
  --volume "$AGENT_ENV_DOCTOR_HOST:/tmp/agent-env-doctor.host:ro" \
  "${MISE_CONFIG_MOUNT[@]}" \
  --env PI_SANDBOX_RUN_MODE="$RUN_MODE" \
  --security-opt no-new-privileges:true \
  --cap-drop ALL \
  --entrypoint bash \
  "$IMAGE_NAME" \
  -lc '
  set -euo pipefail

  export MISE_DATA_DIR=/root/.local/share/mise
  export MISE_CONFIG_DIR=/root/.config/mise
  export MISE_CACHE_DIR=/root/.cache/mise
  export PATH="/root/.local/share/mise/shims:/root/.cargo/bin:/root/.local/bin:/usr/local/bin:$PATH"
  export RUSTUP_INIT_SKIP_PATH_CHECK=yes

  mkdir -p \
    /persist/.pi \
    /persist/.cache/mise \
    /persist/.local/share/mise \
    /persist/.local/bin \
    /persist/.rustup \
    /persist/.cargo \
    /root/.cache \
    /root/.local/share \
    /root/.config

  rm -rf /root/.pi
  ln -s /persist/.pi /root/.pi

  rm -rf /root/.cache/mise
  ln -s /persist/.cache/mise /root/.cache/mise

  rm -rf /root/.local/share/mise
  ln -s /persist/.local/share/mise /root/.local/share/mise

  rm -rf /root/.local/bin
  ln -s /persist/.local/bin /root/.local/bin

  if [ ! -f /root/.local/bin/agent-env-doctor ]; then
    cp /tmp/agent-env-doctor.host /root/.local/bin/agent-env-doctor
    chmod 755 /root/.local/bin/agent-env-doctor
  fi

  rm -rf /root/.rustup
  ln -s /persist/.rustup /root/.rustup

  rm -rf /root/.cargo
  ln -s /persist/.cargo /root/.cargo

  mise install
  mise reshim

  case "${PI_SANDBOX_RUN_MODE:-pi}" in
  doctor)
    exec agent-env-doctor "$@"
    ;;

  pi)
    echo "Running agent-env-doctor preflight..."
    if ! agent-env-doctor; then
      echo "agent-env-doctor failed. Pi will not start." >&2
      exit 1
    fi

    echo "agent-env-doctor OK. Starting pi..."
    exec pi "$@"
    ;;

  *)
    echo "Unknown mode: ${PI_SANDBOX_RUN_MODE}" >&2
    exit 1
    ;;
  esac  
' bash "$@"