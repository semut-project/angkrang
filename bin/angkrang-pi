#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="$(readlink -f -- "$0" 2>/dev/null || printf '%s\n' "$0")"
SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$SCRIPT_PATH")" && pwd)"
VERSIONS_FILE="${ANGKRANG_VERSIONS_FILE:-$SCRIPT_DIR/../docker/pi/versions.env}"

# shellcheck disable=SC1090
if [ -f "$VERSIONS_FILE" ]; then
  . "$VERSIONS_FILE"
else
  echo "angkrang pi setup error: versions file not found" >&2
  echo "  path: $VERSIONS_FILE" >&2
  echo "  tip: reinstall angkrang or set ANGKRANG_VERSIONS_FILE" >&2
  exit 1
fi

IMAGE_NAME="${ANGKRANG_PI_IMAGE:-angkrang-pi}"
CONTAINER_NAME="${ANGKRANG_PI_CONTAINER:-angkrang-pi}"
CONTAINER_WORKDIR="/workspace"

DOCKERFILE_PATH="${ANGKRANG_PI_DOCKERFILE:-$SCRIPT_DIR/../docker/pi/Dockerfile}"
BUILD_CONTEXT="${ANGKRANG_PI_BUILD_CONTEXT:-$SCRIPT_DIR/../docker}"

MISE_CONFIG_HOST="${ANGKRANG_MISE_CONFIG_HOST:-$HOME/.config/mise}"
ANGKRANG_DOCTOR_HOST="${ANGKRANG_DOCTOR_HOST:-$HOME/.local/bin/angkrang-doctor}"

RUN_MODE="pi"
if [ "${1:-}" = "doctor" ]; then
  RUN_MODE="doctor"
  shift
fi

docker volume inspect angkrang-pi-state >/dev/null 2>&1 \
  || docker volume create angkrang-pi-state >/dev/null

if [ ! -f "$ANGKRANG_DOCTOR_HOST" ]; then
  echo "angkrang-doctor not found: $ANGKRANG_DOCTOR_HOST" >&2
  exit 1
fi

if [ ! -f "$DOCKERFILE_PATH" ]; then
  echo "angkrang pi setup error: Dockerfile not found" >&2
  echo "  path: $DOCKERFILE_PATH" >&2
  echo "  tip: set ANGKRANG_PI_DOCKERFILE or reinstall angkrang" >&2
  exit 1
fi

if [ ! -d "$BUILD_CONTEXT" ]; then
  echo "angkrang pi setup error: build context not found" >&2
  echo "  path: $BUILD_CONTEXT" >&2
  echo "  tip: set ANGKRANG_PI_BUILD_CONTEXT or reinstall angkrang" >&2
  exit 1
fi

docker build \
  --build-arg NODE_IMAGE_TAG="${NODE_IMAGE_TAG:?missing NODE_IMAGE_TAG}" \
  --build-arg NODE_IMAGE_DIGEST="${NODE_IMAGE_DIGEST:?missing NODE_IMAGE_DIGEST}" \
  -t "$IMAGE_NAME" \
  -f "$DOCKERFILE_PATH" \
  "$BUILD_CONTEXT"

MISE_CONFIG_MOUNT=()
if [ -d "$MISE_CONFIG_HOST" ]; then
  MISE_CONFIG_MOUNT=(--volume "$MISE_CONFIG_HOST:/root/.config/mise:ro")
fi

docker run --rm -it \
  --name "$CONTAINER_NAME" \
  --workdir "$CONTAINER_WORKDIR" \
  --volume "$PWD:$CONTAINER_WORKDIR" \
  --volume angkrang-pi-state:/persist \
  --volume "$ANGKRANG_DOCTOR_HOST:/tmp/angkrang-doctor.host:ro" \
  "${MISE_CONFIG_MOUNT[@]}" \
  --env ANGKRANG_PI_RUN_MODE="$RUN_MODE" \
  --security-opt no-new-privileges:true \
  --cap-drop ALL \
  --entrypoint bash \
  "$IMAGE_NAME" \
  -lc '
  set -euo pipefail

  export MISE_DATA_DIR=/root/.local/share/mise
  export MISE_CONFIG_DIR=/root/.config/mise
  export MISE_CACHE_DIR=/root/.cache/mise
  export PATH="/root/.local/share/mise/shims:/root/.cargo/bin:/root/.local/bin:/usr/local/bin:$PATH"
  export RUSTUP_INIT_SKIP_PATH_CHECK=yes

  mkdir -p \
    /persist/.pi \
    /persist/.cache/mise \
    /persist/.local/share/mise \
    /persist/.local/bin \
    /persist/.rustup \
    /persist/.cargo \
    /root/.cache \
    /root/.local/share \
    /root/.config

  rm -rf /root/.pi
  ln -s /persist/.pi /root/.pi

  rm -rf /root/.cache/mise
  ln -s /persist/.cache/mise /root/.cache/mise

  rm -rf /root/.local/share/mise
  ln -s /persist/.local/share/mise /root/.local/share/mise

  rm -rf /root/.local/bin
  ln -s /persist/.local/bin /root/.local/bin

  if [ ! -f /root/.local/bin/angkrang-doctor ]; then
    cp /tmp/angkrang-doctor.host /root/.local/bin/angkrang-doctor
    chmod 755 /root/.local/bin/angkrang-doctor
  fi

  rm -rf /root/.rustup
  ln -s /persist/.rustup /root/.rustup

  rm -rf /root/.cargo
  ln -s /persist/.cargo /root/.cargo

  mise install
  mise reshim

  case "${ANGKRANG_PI_RUN_MODE:-pi}" in
  doctor)
    exec angkrang-doctor "$@"
    ;;

  pi)
    echo "Running angkrang-doctor preflight..."
    if ! angkrang-doctor; then
      echo "angkrang-doctor failed. Pi will not start." >&2
      exit 1
    fi

    echo "angkrang-doctor OK. Starting pi..."
    exec pi "$@"
    ;;

  *)
    echo "Unknown mode: ${ANGKRANG_PI_RUN_MODE}" >&2
    exit 1
    ;;
  esac  
' bash "$@"